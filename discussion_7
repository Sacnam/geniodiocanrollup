3e UserIntent {\n        let q \u003d query.to_lowercase();\n        \n        if q.contains(\"analizza\") || q.contains(\"validità\") || q.contains(\"statistica\") {\n            UserIntent::DeepAnalysis\n        } else if q.contains(\"trova\") || q.contains(\"documenti su\") {\n            UserIntent::DataRetrieval\n        } else if q.len() \u003c 100 {\n            UserIntent::QuickSummary\n        } else {\n            UserIntent::Unknown\n        }\n    }\n\n    // Seleziona il modello ottimale basandosi sull\u0027intento (Commandment #7: Explicit Error Handling)\n    pub fn route(\u0026self, query: \u0026str) -\u003e Result\u003cAIModel, String\u003e {\n        if query.is_empty() {\n            return Err(\"Query vuota: impossibile instradare.\".to_string());\n        }\n\n        let intent \u003d self.classify_intent(query);\n\n        match intent {\n            UserIntent::QuickSummary \u003d\u003e Ok(AIModel::Flash),\n            UserIntent::DeepAnalysis \u003d\u003e Ok(AIModel::Reasoning),\n            UserIntent::DataRetrieval \u003d\u003e Ok(AIModel::GraphAgent),\n            UserIntent::Unknown \u003d\u003e {\n                // Default cautelativo: usa il modello di ragionamento se l\u0027intento è ambiguo\n                Ok(AIModel::Reasoning)\n            }\n        }\n    }\n}\n\nfn main() {\n    let router \u003d IntentRouter::new(0.85);\n    let user_query \u003d \"Analizza la validità statistica di questo paper.\";\n\n    match router.route(user_query) {\n        Ok(model) \u003d\u003e println!(\"Query: \u0027{}\u0027 -\u003e Instradata a: {:?}\", user_query, model),\n        Err(e) \u003d\u003e eprintln!(\"Errore critico: {}\", e),\n    }\n}\n```\n\n---\n\n### Part 2: THE EXPLANATION (The Design Notes)\n\n// --- DESIGN NOTES --- //\n\n*   **Rust Core (Performance Assoluta):** Il report menziona \"Tauri v2\" e \"Rust\". Questo codice gira a livello nativo. Non c\u0027è il \"peso\" di JavaScript nel decidere dove mandare i dati. È istantaneo.